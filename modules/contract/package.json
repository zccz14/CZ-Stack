{
  "name": "@cz-stack/contract",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm --dir ../.. exec tsdown --config tsdown.config.ts --entry modules/contract/src/index.ts --out-dir modules/contract/dist",
    "typecheck": "pnpm exec tsc --project tsconfig.json --noEmit",
    "test": "pnpm --dir ../.. exec vitest run tests/contracts/contract-package.test.ts"
  },
  "dependencies": {
    "zod": "^4.1.12"
  }
}
